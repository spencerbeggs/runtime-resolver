{
	"$schema": "https://turborepo.com/schema.v2.json",
	"globalPassThroughEnv": ["GITHUB_ACTIONS", "CI"],
	"tasks": {
		"build:dev": {
			"cache": true,
			"dependsOn": ["types:check"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!**/*.test.ts",
				"!**/*.spec.ts",
				"!**/*.md",
				"!.changeset/**",
				"!.claude/**",
				"!.github/**",
				"!.husky/**",
				"!.vscode/**",
				"!vitest.config.ts",
				"!vitest.setup.ts"
			],
			"outputLogs": "full",
			"outputs": ["dist/dev/**", ".rslib/declarations/dev/**"]
		},
		"build:prod": {
			"cache": true,
			"dependsOn": ["types:check"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!**/*.test.ts",
				"!**/*.spec.ts",
				"!**/*.md",
				"!.changeset/**",
				"!.claude/**",
				"!.github/**",
				"!.husky/**",
				"!.vscode/**",
				"!vitest.config.ts",
				"!vitest.setup.ts"
			],
			"outputLogs": "full",
			"outputs": ["dist/npm/**", "dist/github/**", ".rslib/declarations/npm/**"]
		},
		"generate:defaults": {
			"cache": true,
			"inputs": [
				"lib/scripts/generate-defaults.mts",
				"src/schemas/**",
				"src/services/GitHubClient.ts",
				"src/services/OctokitInstance.ts",
				"src/layers/GitHubClientLive.ts",
				"src/layers/GitHubTokenAuth.ts",
				"src/errors/**"
			],
			"outputLogs": "new-only",
			"outputs": ["src/data/node-defaults.ts", "src/data/bun-defaults.ts", "src/data/deno-defaults.ts"],
			"passThroughEnv": ["GITHUB_PERSONAL_ACCESS_TOKEN", "GITHUB_TOKEN"]
		},
		"generate:json-schema": {
			"cache": true,
			"inputs": ["lib/scripts/generate-json-schema.mts", "src/cli/schemas/response.ts"],
			"outputLogs": "new-only",
			"outputs": ["runtime-resolver.schema.json"]
		},
		"types:check": {
			"cache": true,
			"dependsOn": ["generate:defaults"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!**/*.md",
				"!.changeset/**",
				"!.claude/**",
				"!.github/**",
				"!.husky/**",
				"!.vscode/**"
			],
			"outputLogs": "errors-only",
			"outputs": []
		}
	}
}
