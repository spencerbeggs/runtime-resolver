{
	"name": "runtime-resolver",
	"version": "0.3.12",
	"private": true,
	"description": "Resolve semver-compatible versions of Node.js, Bun, and Deno runtimes with Effect-based architecture and offline fallback.",
	"keywords": [
		"node",
		"bun",
		"deno",
		"runtime",
		"version",
		"semver",
		"resolver",
		"ci",
		"github-actions",
		"effect",
		"cli"
	],
	"homepage": "https://github.com/spencerbeggs/runtime-resolver#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/runtime-resolver/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/runtime-resolver.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"runtime-resolver": "./src/cli/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "node savvy.build.ts --target dev",
		"build:meta": "node savvy.build.ts --target meta",
		"build:prod": "node savvy.build.ts --target prod",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"ci:version": "savvy changeset version && biome format --write .",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@octokit/auth-app": "^8.2.0",
		"octokit": "^5.0.5",
		"semver-effect": "^0.2.1"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.4.0",
		"@savvy-web/silk": "^0.4.2",
		"@savvy-web/vitest": "^1.5.0",
		"tsx": "catalog:silk"
	},
	"peerDependencies": {
		"@effect/cli": "catalog:silkPeers",
		"@effect/platform": "catalog:silkPeers",
		"@effect/platform-node": "catalog:silkPeers",
		"effect": "catalog:silkPeers"
	},
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.3.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/runtime-resolver"
		}
	}
}
